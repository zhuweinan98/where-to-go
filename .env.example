# Copy to .env if needed
# PYTHON_VERSION=3.10

# ---------- 和风天气 QWeather（可选）----------
# 同时配置 HOST + KEY 后，天气与推荐逻辑使用实时实况；失败或未配置时回退 Mock。
# 控制台 API Host（可带或不带 https://）
# QWEATHER_HOST=https://xxxx.re.qweatherapi.com
# 二选一：API KEY（控制台「API KEY」凭据），或 JWT（控制台文档生成后粘贴，会过期）
# QWEATHER_KEY=
# QWEATHER_BEARER_TOKEN=
# QWEATHER_AUTH=auto   # 仅 API KEY 时：Header 遇 401 再试 URL key=
# QWEATHER_TIMEOUT=10
# QWEATHER_DEBUG=1   # 开启后在运行服务的终端打印 [qweather] 行（stdout）

# ---------- LLM（可选）----------
# LLM_MODE=off          # 默认：仅规则引擎（与单测一致）
# LLM_MODE=ollama       # 当前已接：本地 Ollama（/v1 兼容，需 ollama serve + ollama pull 模型）

# Ollama（示例模型名按 ollama list 填写，如 qwen3:4b）
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3:4b
# OLLAMA_API_KEY=ollama
# OLLAMA_HTTP_TIMEOUT=600   # 秒，本地推理慢时可加大

# ---------- 云端预留（代码未接，勿指望 LLM_MODE=openai 能调通）----------
# LLM_MODE=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4o-mini
