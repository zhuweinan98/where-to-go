# Copy to .env if needed
# PYTHON_VERSION=3.10

# ---------- LLM（可选）----------
# LLM_MODE=off          # 默认：仅规则引擎（与单测一致）
# LLM_MODE=ollama       # 当前已接：本地 Ollama（/v1 兼容，需 ollama serve + ollama pull 模型）

# Ollama（示例模型名按 ollama list 填写，如 qwen3:4b）
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3:4b
# OLLAMA_API_KEY=ollama
# OLLAMA_HTTP_TIMEOUT=600   # 秒，本地推理慢时可加大

# ---------- 云端预留（代码未接，勿指望 LLM_MODE=openai 能调通）----------
# LLM_MODE=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4o-mini
