# ---- Weather (QWeather，可选) ----
QWEATHER_HOST=
QWEATHER_KEY=
QWEATHER_BEARER_TOKEN=
QWEATHER_AUTH=auto
QWEATHER_TIMEOUT=10

# ---- LLM ----
# off / ollama / openai
LLM_MODE=off
LLM_DEBUG=0

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_API_KEY=ollama
OLLAMA_HTTP_TIMEOUT=600

# OpenAI-compatible（DeepSeek）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_HTTP_TIMEOUT=120

# ---- RAG Embedding ----
# openai 模式默认：deepseek-embedding
# ollama 模式常用：nomic-embed-text
RAG_EMBEDDING_MODEL=deepseek-embedding
RAG_EMBEDDING_TIMEOUT=30
