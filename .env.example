# Copy to .env if needed
# PYTHON_VERSION=3.10

# ---------- 和风天气 QWeather（可选）----------
# 同时配置 HOST + KEY 后，天气与推荐逻辑使用实时实况；失败或未配置时回退 Mock。
# 控制台 API Host（可带或不带 https://）
# QWEATHER_HOST=https://xxxx.re.qweatherapi.com
# 二选一：API KEY（控制台「API KEY」凭据），或 JWT（控制台文档生成后粘贴，会过期）
# QWEATHER_KEY=
# QWEATHER_BEARER_TOKEN=
# QWEATHER_AUTH=auto   # 仅 API KEY 时：Header 遇 401 再试 URL key=
# QWEATHER_TIMEOUT=10
# QWEATHER_DEBUG=1   # 开启后在运行服务的终端打印 [qweather] 行（stdout）

# ---------- LLM（可选）----------
# LLM_MODE=off          # 默认：仅规则引擎（与单测一致）
# LLM_MODE=ollama       # 本地 Ollama（/v1 兼容）
# LLM_MODE=openai       # 云端：OpenAI 官方或任意兼容 /v1/chat/completions 的服务

# Ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3:4b
# OLLAMA_API_KEY=ollama
# OLLAMA_HTTP_TIMEOUT=600

# 云端 OpenAI 兼容（DeepSeek / 月之暗面等：改 OPENAI_BASE_URL，模型名按厂商文档）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_HTTP_TIMEOUT=120
# LLM_DEBUG=1   # 终端打印 [llm]：已走云端/本地、城市、model、base_url、token 用量（不打印密钥与正文）

# ---------- RAG Embedding（语义检索，可选）----------
# 默认会尝试复用当前 LLM_MODE 的兼容 embedding 接口（失败自动回退关键词检索）
# RAG_EMBEDDING_MODEL=deepseek-embedding       # DeepSeek 兼容接口建议值（openai 模式）
# RAG_EMBEDDING_MODEL=nomic-embed-text         # ollama 模式常用值（按本机实际模型调整）
# RAG_EMBEDDING_TIMEOUT=30
